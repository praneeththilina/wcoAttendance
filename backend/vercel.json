{
  "version": 2,
  "builds": [
    {
      "src": "src/vercel.ts",
      "use": "@vercel/node"
    }
  ],
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npx prisma generate && tsc --skipLibCheck",
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/src/vercel.ts"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "CORS_ORIGIN": "https://wco-attendance-frontend.vercel.app"
  }
}
