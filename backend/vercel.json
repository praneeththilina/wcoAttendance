{
  "version": 2,
  "builds": [
    {
      "src": "src/vercel.ts",
      "use": "@vercel/node"
    }
  ],
  "installCommand": "pnpm install --legacy-peer-deps",
  "buildCommand": "pnpm prisma generate && pnpm exec tsc",
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/vercel.js"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "CORS_ORIGIN": "https://wco-attendance-frontend.vercel.app"
  }
}
