{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/node"
    }
  ],
  "installCommand": "npm install",
  "buildCommand": "npx prisma generate && npm run build",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/src/vercel.ts"
    },
    {
      "src": "/health",
      "dest": "/src/vercel.ts"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
